    "start": "node server/index.js"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "google-auth-library": "^9.15.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.1.0",
    "gh-pages": "^6.1.1",
    "vite": "^5.1.0"
  }
}
